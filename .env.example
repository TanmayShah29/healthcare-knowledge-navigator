# ── Neo4j (hybrid store: entity graph + vector index over chunks) ────────
# Easiest options: Neo4j Desktop (local) or Neo4j Aura free tier (hosted).
# Vector index requires Neo4j 5.11+ — Aura free tier and current Desktop
# versions both qualify.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── LLM Provider (used by Extractor / Entity Linker / Synthesizer agents) ─
# Same provider-agnostic setup as multi-agent-code-review and
# graphrag-knowledge-assistant. Any provider LangChain's init_chat_model()
# supports:
# anthropic | openai | google_genai | groq | mistralai | xai | ollama
LLM_PROVIDER=google_genai
AGENT_MODEL=gemini-2.5-flash

# Set the ONE key matching your LLM_PROVIDER above (or LLM_API_KEY, which
# always wins regardless of provider).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
GEMINI_API_KEY=your-key-here
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# LLM_API_KEY=

# ── Embeddings provider (used for chunk + question embedding) ────────────
# Defaults to LLM_PROVIDER if unset. Can be split independently, e.g. Gemini
# for chat + OpenAI for embeddings — just set the matching API key above too.
# EMBEDDING_PROVIDER=google_genai
EMBEDDING_MODEL=models/text-embedding-004

# Must match EMBEDDING_MODEL's actual output dimensionality — used to size
# the Neo4j vector index. Common values:
#   768  -> Gemini text-embedding-004 (default above)
#   1536 -> OpenAI text-embedding-3-small
#   3072 -> OpenAI text-embedding-3-large
EMBEDDING_DIMENSIONS=768

# ── Retrieval tuning (hybrid: vector similarity + graph traversal) ───────
# How many chunks the vector similarity search returns per query.
TOP_K_CHUNKS=5

# How many hops out from linked seed entities to traverse in the graph.
MAX_HOPS=2

# Cap on structured facts pulled back per query.
MAX_TRIPLES=40

# ── Ingestion tuning ───────────────────────────────────────────────────────
# Rough chunk size (characters) when splitting a document before embedding
# and running the Extractor agent on each chunk.
CHUNK_SIZE=1200

# ── Confidence scoring thresholds ─────────────────────────────────────────
# Final 0-1 score >= HIGH -> "High", >= MEDIUM -> "Medium", else "Low".
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_MEDIUM_THRESHOLD=0.5
